{
  "version": 1,
  "clusters": [
    {
      "cluster_id": "unsafe-boundary",
      "prompt": "prompts/clusters/unsafe-boundary.md",
      "consolidated": true,
      "gate": "always",
      "passes": [
        { "bug_class": "unsafe-reaching-api", "prefix": "URAPI" },
        { "bug_class": "transmute-misuse",    "prefix": "TRANS" },
        { "bug_class": "raw-pointer-arith",   "prefix": "RAWPTR" },
        { "bug_class": "pointer-cast",        "prefix": "PTRCAST" },
        { "bug_class": "repr-c-layout",       "prefix": "REPRC" },
        { "bug_class": "enum-discriminant",   "prefix": "ENUMUB" },
        { "bug_class": "safety-doc",          "prefix": "SAFETYDOC" },
        { "bug_class": "debug-assert-safety", "prefix": "DEBUGSAFETY" }
      ]
    },
    {
      "cluster_id": "memory-safety",
      "prompt": "prompts/clusters/memory-safety.md",
      "consolidated": false,
      "gate": "has_unsafe",
      "passes": [
        { "bug_class": "uninitialized-read",    "prefix": "UNINITREAD", "prompt": "prompts/general/uninitialized-read-finder.md" },
        { "bug_class": "vec-set-len-uninit",    "prefix": "SETLEN",     "prompt": "prompts/general/vec-set-len-uninit-finder.md" },
        { "bug_class": "invalid-free",          "prefix": "INVFREE",    "prompt": "prompts/general/invalid-free-finder.md" },
        { "bug_class": "use-after-free",        "prefix": "UAF",        "prompt": "prompts/general/use-after-free-finder.md" },
        { "bug_class": "double-free",           "prefix": "DFREE",      "prompt": "prompts/general/double-free-finder.md" },
        { "bug_class": "buffer-overflow-unsafe","prefix": "BOF",        "prompt": "prompts/general/buffer-overflow-unsafe-finder.md" },
        { "bug_class": "union-ub",              "prefix": "UNIONUB",    "prompt": "prompts/general/union-ub-finder.md" },
        { "bug_class": "panic-unwind-unsafe",   "prefix": "PANICUNWIND","prompt": "prompts/general/panic-unwind-unsafe-finder.md" }
      ]
    },
    {
      "cluster_id": "concurrency-locking",
      "prompt": "prompts/clusters/concurrency-locking.md",
      "consolidated": true,
      "gate": "has_concurrency",
      "passes": [
        { "bug_class": "double-lock-deadlock", "prefix": "DLOCK" },
        { "bug_class": "abba-deadlock",        "prefix": "ABBA" },
        { "bug_class": "condvar-misuse",       "prefix": "CONDVAR" },
        { "bug_class": "channel-starvation",   "prefix": "CHANSTARVE" },
        { "bug_class": "once-reentrancy",      "prefix": "ONCEREENTRY" },
        { "bug_class": "reentrancy-unsafe",    "prefix": "REENTRANT" }
      ]
    },
    {
      "cluster_id": "concurrency-data-race",
      "prompt": "prompts/clusters/concurrency-data-race.md",
      "consolidated": false,
      "gate": "has_concurrency",
      "passes": [
        { "bug_class": "atomic-race",        "prefix": "ATOMICRACE",   "prompt": "prompts/general/atomic-race-finder.md" },
        { "bug_class": "unsafe-sync-impl",   "prefix": "UNSAFESYNC",   "prompt": "prompts/general/unsafe-sync-impl-finder.md", "requires": ["has_unsafe"] },
        { "bug_class": "send-sync-bounds",   "prefix": "SENDSYNCBOUND","prompt": "prompts/general/send-sync-bounds-finder.md" },
        { "bug_class": "shared-memory-race", "prefix": "SHMRACE",      "prompt": "prompts/general/shared-memory-race-finder.md" },
        { "bug_class": "static-mut-race",    "prefix": "STATICMUT",    "prompt": "prompts/general/static-mut-race-finder.md", "requires": ["has_unsafe"] }
      ]
    },
    {
      "cluster_id": "panic-dos",
      "prompt": "prompts/clusters/panic-dos.md",
      "consolidated": false,
      "gate": "always",
      "passes": [
        { "bug_class": "resource-exhaustion",  "prefix": "RESEXHAUST",  "prompt": "prompts/general/resource-exhaustion-finder.md" },
        { "bug_class": "unwrap-on-untrusted",  "prefix": "UNWRAP",      "prompt": "prompts/general/unwrap-on-untrusted-finder.md" },
        { "bug_class": "arithmetic-overflow",  "prefix": "ARITHOFL",    "prompt": "prompts/general/arithmetic-overflow-finder.md" },
        { "bug_class": "assertion-reachable",  "prefix": "ASSERTREACH", "prompt": "prompts/general/assertion-reachable-finder.md" },
        { "bug_class": "out-of-bounds-index",  "prefix": "OOBIDX",      "prompt": "prompts/general/out-of-bounds-index-finder.md" },
        { "bug_class": "str-slice-boundary",   "prefix": "STRSLICE",    "prompt": "prompts/general/str-slice-boundary-finder.md" },
        { "bug_class": "refcell-borrow-panic", "prefix": "REFCELLPANIC", "prompt": "prompts/general/refcell-borrow-panic-finder.md" }
      ]
    },
    {
      "cluster_id": "recursion-dos",
      "prompt": "prompts/clusters/recursion-dos.md",
      "consolidated": false,
      "max_passes_per_worker": 1,
      "gate": "always",
      "passes": [
        { "bug_class": "recursive-deserialize-stack-overflow", "prefix": "RECURSEDES",  "prompt": "prompts/general/recursive-deserialize-stack-overflow-finder.md" },
        { "bug_class": "recursive-format-stack-overflow",      "prefix": "RECURSEFMT",  "prompt": "prompts/general/recursive-format-stack-overflow-finder.md" },
        { "bug_class": "recursive-drop-stack-overflow",        "prefix": "RECURSEDROP", "prompt": "prompts/general/recursive-drop-stack-overflow-finder.md" }
      ]
    },
    {
      "cluster_id": "error-handling",
      "prompt": "prompts/clusters/error-handling.md",
      "consolidated": false,
      "gate": "always",
      "passes": [
        { "bug_class": "result-discarded", "prefix": "RESDISC",   "prompt": "prompts/general/result-discarded-finder.md" },
        { "bug_class": "drop-panic",       "prefix": "DROPPANIC", "prompt": "prompts/general/drop-panic-finder.md" },
        { "bug_class": "lossy-from-into",  "prefix": "LOSSYFROM", "prompt": "prompts/general/lossy-from-into-finder.md" },
        { "bug_class": "lossy-str-conversion", "prefix": "LOSSYSTR", "prompt": "prompts/general/lossy-str-conversion-finder.md" },
        { "bug_class": "bufwriter-unflushed",  "prefix": "BUFFLUSH", "prompt": "prompts/general/bufwriter-unflushed-finder.md" }
      ]
    },
    {
      "cluster_id": "logic-correctness",
      "prompt": "prompts/clusters/logic-correctness.md",
      "consolidated": false,
      "gate": "always",
      "passes": [
        { "bug_class": "ord-eq-hash",               "prefix": "ORDEQHASH",    "prompt": "prompts/general/ord-eq-hash-finder.md" },
        { "bug_class": "adversarial-trait",         "prefix": "TRAITADV",     "prompt": "prompts/general/adversarial-trait-finder.md", "requires": ["has_unsafe"] },
        { "bug_class": "closure-panic",             "prefix": "CLOSUREPANIC", "prompt": "prompts/general/closure-panic-finder.md", "requires": ["has_unsafe"] },
        { "bug_class": "float-edge",                "prefix": "FLOATEDGE",    "prompt": "prompts/general/float-edge-finder.md" },
        { "bug_class": "string-comparison",         "prefix": "STRCMP",       "prompt": "prompts/general/string-comparison-finder.md" },
        { "bug_class": "serialize-struct-mismatch", "prefix": "SERFIELDS",    "prompt": "prompts/general/serialize-struct-mismatch-finder.md" },
        { "bug_class": "nondeterminism",            "prefix": "NONDET",       "prompt": "prompts/general/nondeterminism-finder.md" },
        { "bug_class": "collection-key-mutation",   "prefix": "KEYMUT",       "prompt": "prompts/general/collection-key-mutation-finder.md" }
      ]
    },
    {
      "cluster_id": "ffi-cross-language",
      "prompt": "prompts/clusters/ffi-cross-language.md",
      "consolidated": false,
      "gate": "has_ffi",
      "passes": [
        { "bug_class": "cstring-dangling", "prefix": "CSTRDANGLE",   "prompt": "prompts/general/cstring-dangling-finder.md" },
        { "bug_class": "abi-mismatch",     "prefix": "ABIMISMATCH",  "prompt": "prompts/general/abi-mismatch-finder.md" },
        { "bug_class": "repr-c-padding",   "prefix": "REPRCPAD",     "prompt": "prompts/general/repr-c-padding-finder.md" },
        { "bug_class": "opaque-pointer",   "prefix": "OPAQUEPTR",    "prompt": "prompts/general/opaque-pointer-finder.md" },
        { "bug_class": "foreign-drop",     "prefix": "FOREIGNDROP",  "prompt": "prompts/general/foreign-drop-finder.md" },
        { "bug_class": "closure-ffi",      "prefix": "CLOSUREFFI",   "prompt": "prompts/general/closure-ffi-finder.md" },
        { "bug_class": "dyn-trait-ffi",    "prefix": "DYNFFI",       "prompt": "prompts/general/dyn-trait-ffi-finder.md" }
      ]
    },
    {
      "cluster_id": "layout-safety",
      "prompt": "prompts/clusters/layout-safety.md",
      "consolidated": false,
      "gate": "has_packed_repr",
      "passes": [
        { "bug_class": "packed-field-ref", "prefix": "PACKEDREF", "prompt": "prompts/general/packed-field-ref-finder.md" }
      ]
    },
    {
      "cluster_id": "async-runtime",
      "prompt": "prompts/clusters/async-runtime.md",
      "consolidated": false,
      "gate": "has_async",
      "passes": [
        { "bug_class": "async-blocking",    "prefix": "ASYNCBLOCK",    "prompt": "prompts/general/async-blocking-finder.md" },
        { "bug_class": "cancel-safety",     "prefix": "CANCELSAFETY",  "prompt": "prompts/general/cancel-safety-finder.md" },
        { "bug_class": "select-bias",       "prefix": "SELECTBIAS",    "prompt": "prompts/general/select-bias-finder.md" }
      ]
    },
    {
      "cluster_id": "static-hygiene",
      "prompt": "prompts/clusters/static-hygiene.md",
      "consolidated": false,
      "gate": "always",
      "passes": [
        { "bug_class": "cargo-lint-config", "prefix": "CARGOLINT",     "prompt": "prompts/general/cargo-lint-config-finder.md" },
        { "bug_class": "msrv-mismatch",     "prefix": "MSRV",          "prompt": "prompts/general/msrv-mismatch-finder.md" },
        { "bug_class": "deprecated-api",    "prefix": "DEPRECAPI",     "prompt": "prompts/general/deprecated-api-finder.md" }
      ]
    },
    {
      "cluster_id": "resource-handling",
      "prompt": "prompts/clusters/resource-handling.md",
      "consolidated": false,
      "gate": "always",
      "passes": [
        { "bug_class": "raw-fd-lifecycle", "prefix": "RAWFD",    "prompt": "prompts/general/raw-fd-lifecycle-finder.md" },
        { "bug_class": "destructor-skip",  "prefix": "DROPSKIP", "prompt": "prompts/general/destructor-skip-finder.md" }
      ]
    },
    {
      "cluster_id": "input-os-safety",
      "prompt": "prompts/clusters/input-os-safety.md",
      "consolidated": false,
      "gate": "has_fs_io",
      "passes": [
        { "bug_class": "path-traversal-join", "prefix": "PATHJOIN",  "prompt": "prompts/general/path-traversal-join-finder.md" },
        { "bug_class": "toctou",              "prefix": "TOCTOU",    "prompt": "prompts/general/toctou-finder.md" }
      ]
    },
    {
      "cluster_id": "info-disclosure",
      "prompt": "prompts/clusters/info-disclosure.md",
      "consolidated": false,
      "gate": "always",
      "passes": [
        { "bug_class": "pointer-exposure", "prefix": "PTREXPOSE", "prompt": "prompts/general/pointer-exposure-finder.md" }
      ]
    }
  ]
}
